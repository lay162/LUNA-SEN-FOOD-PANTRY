# Copy this file to `.env.local` and fill in values (Vite reads `.env.local` automatically).
# Never commit `.env.local` — it is gitignored via `*.local`.

# --- Firebase (optional, Spark/free tier) ---
# Firebase Console → Project settings → Your apps → Web app → copy the config object.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- EmailJS (optional, free tier) — backup when Firestore fails or if you skip Firebase ---
# https://www.emailjs.com — create a service + template; template should accept form_type and form_body (or match emailJsSubmit.js).
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
