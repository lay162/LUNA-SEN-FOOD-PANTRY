# Copy what you need into `.env.local` (Vite reads `.env.local` automatically).
# Never commit `.env.local` — gitignored via `*.local`.
#
# .env.example = repo template + docs only.
# .env.local   = real Firebase keys, EmailJS, flags (your machine).
#
# GitHub Actions (Firebase Hosting on push to main): add the same VITE_* names as repository
# secrets, plus FIREBASE_TOKEN from `firebase login:ci` (run once on your PC). See
# .github/workflows/deploy-firebase-hosting.yml. Pause Netlify auto-deploys if you only want Firebase.

# --- Firebase ---
# Console → Project settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Public site URL (QR codes embed this domain; default in code is https://lunasenpantry.co.uk) ---
# VITE_SITE_URL=https://lunasenpantry.co.uk

# --- Form email: Cloud Function + Namecheap Private Email SMTP (production) ---
# Blaze + Functions. Region europe-west2 (must match FIREBASE_FUNCTIONS_REGION in src/firebase.js).
#   firebase functions:secrets:set SMTP_USER    # full address, e.g. admin@lunasenpantry.co.uk
#   firebase functions:secrets:set SMTP_PASS    # mailbox password (app password if 2FA)
#   firebase deploy --only functions:sendFormNotificationEmail
# Then set VITE_FORM_NOTIFY_CLOUD=true here and on Netlify.
# Defaults: mail.privateemail.com:587, MAIL_FROM/MAIL_TO admin@lunasenpantry.co.uk (see functions/index.js).
VITE_FORM_NOTIFY_CLOUD=

# --- EmailJS (fallback when Firestore fails, or if cloud flag above is off) ---
# https://www.emailjs.com — can use Private Email SMTP in the EmailJS dashboard.
# Template: {{{form_html}}}, {{form_subject}}, {{form_body}}, {{form_type}}, {{reply_to}}
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
